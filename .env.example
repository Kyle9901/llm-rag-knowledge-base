# ========== Docker 镜像（国内无法访问 Docker Hub 时取消注释，镜像站以你环境可用为准）==========
# DOCKER_PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
# DOCKER_REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
# DOCKER_POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine

# ---------------------------------------------------------------------------
# 本文件为模板：仅含占位符，可安全提交到 Git。
# 复制为 .env 后填入真实密钥；.env 已被 .gitignore 忽略，切勿提交。
# ---------------------------------------------------------------------------

APP_NAME=RAG Multi-Agent Backend
APP_VERSION=2.1.0
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
API_AUTH_TOKEN=CHANGE_ME_TO_A_STRONG_RANDOM_TOKEN

OPENAI_API_KEY=your_deepseek_or_openai_compatible_key_here
ZHIPU_API_KEY=your_zhipu_embedding_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_EMBEDDING_MODEL=embedding-3
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
EMBEDDING_CHUNK_SIZE=60

DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/rag_backend
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---------- 联网搜索（Tavily）----------
# 配置 TAVILY_API_KEY 并重启 API 后，智能体即可调用联网检索（无需额外开关）。
TAVILY_API_KEY=your_tavily_api_key_optional

# ---------- LangSmith 轨迹（网页上看 Runs / 工具调用）----------
# 三选一开启：LANGCHAIN_TRACING_V2=true 或 LANGSMITH_TRACING=true
# API Key 在 LangSmith → Settings → API Keys；填 LANGCHAIN_API_KEY 或 LANGSMITH_API_KEY 均可。
# 项目名称须与网页上项目完全一致（例如控制台写的是「大模型项目」则下面也要写中文名）。
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=rag-multi-agent-backend
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

CHROMA_PERSIST_DIR=/app/chroma_db
CHROMA_COLLECTION_NAME=knowledge_base
UPLOAD_DIR=/app/data/uploads
TEXT_SPLITTER_CHUNK_SIZE=800
TEXT_SPLITTER_CHUNK_OVERLAP=100
RETRIEVER_SEARCH_K=10
OCR_DPI=300
OCR_LANGUAGE=chi_sim+eng
TESSERACT_CMD=/usr/bin/tesseract
